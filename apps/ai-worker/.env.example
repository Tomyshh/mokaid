# mokaid AI worker — local development
PHOENIX_API_URL=http://localhost:4000
WORKER_AUTH_TOKEN=dev-worker-token

# LLM provider (optional in dev — planner falls back to deterministic plans)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic (Claude) — preferred text provider when set
ANTHROPIC_API_KEY=

# DeepSeek — cheapest tier for bulk/background work.
# When set, "fast" quality routes to DeepSeek V4-Flash instead of Claude.
DEEPSEEK_API_KEY=

# Run persistence (optional): Postgres DSN for LangGraph checkpoints +
# saved run requests, so missions paused on approvals survive restarts.
DATABASE_URL=postgresql://mokaid:mokaid_dev_password@localhost/mokaid_dev

# LangSmith observability (optional): set the key to trace every agent run.
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=mokaid-ai-worker

# SQS consumption (production only — leave empty in dev, dispatch is HTTP)
AI_RUNS_QUEUE_URL=
AWS_REGION=

# Object storage (MinIO locally, S3 in production)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=mokaid
S3_SECRET_ACCESS_KEY=mokaid_dev_password
